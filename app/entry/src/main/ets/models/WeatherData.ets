/**
 * 天气数据模型
 */
export interface WeatherData {
  // 当前天气
  temp: number           // 温度
  feelsLike: number      // 体感温度
  text: string           // 天气状况文字
  icon: string           // 天气图标代码
  humidity: number       // 湿度百分比
  windDir: string        // 风向
  windSpeed: number      // 风速 km/h
  pressure: number       // 气压
  visibility: number     // 能见度 km
  updateTime: string     // 更新时间
  
  // 位置信息
  location: string       // 位置名称
  locationId?: string    // 位置ID
  province?: string      // 省份
  city?: string          // 城市
  latitude?: number      // 纬度
  longitude?: number     // 经度
  
  // 未来预报（可选）
  forecast?: WeatherForecast[]
}

/**
 * 天气预报
 */
export interface WeatherForecast {
  date: string           // 日期
  tempMax: number        // 最高温度
  tempMin: number        // 最低温度
  textDay: string        // 白天天气
  textNight: string      // 夜间天气
  iconDay: string        // 白天图标
  iconNight: string      // 夜间图标
}

