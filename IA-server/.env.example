# ============================================================
# 智慧农业系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# 服务端口
SERVER_PORT=8123

# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/agriculture?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&characterEncoding=utf8
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# LangChain4j AI 配置
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api-inference.modelscope.cn/v1
AI_MODEL_NAME=moonshotai/Kimi-K2.5

# 和风天气 API
WEATHER_API_KEY=your_weather_api_key_here
WEATHER_API_HOST=m66r6yk5c4.re.qweatherapi.com

# JWT 配置
JWT_SECRET=your-256-bit-secret-key-here
JWT_EXPIRATION=86400000

# Spring Profile
SPRING_PROFILES_ACTIVE=local

# 日志级别
LOG_LEVEL=DEBUG
